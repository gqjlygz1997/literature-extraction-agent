# Copy this file to .env and fill in your own keys.
# Never commit the real .env file.

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------
# The code uses an OpenAI-compatible chat API for paper filtering, labeling
# config generation, evidence labeling, and extraction.

LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-k2.6
LLM_TEMPERATURE=0.6

# Optional: use a different model for extraction.
# If empty, extraction falls back to LLM_MODEL.
EXTRACTOR_MODEL=
EXTRACTOR_TEMPERATURE=
EXTRACTOR_MAX_TOKENS=4000
EXTRACTOR_TIMEOUT=90

# Optional: cap evidence-labeling responses.
LABELER_MAX_TOKENS=1500

# DSPy cache directory. Use a writable local path.
DSPY_CACHEDIR=/tmp/dspy_cache

# ---------------------------------------------------------------------------
# Embedding provider
# ---------------------------------------------------------------------------
# Default recommended setup: Google AI Studio Gemini embedding.

GEMINI_API_KEY=your_gemini_api_key_here
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBED_BATCH=32

# Optional OpenAI-compatible embedding fallback.
# If you use this route, set EMBEDDING_PROVIDER=openai in generated/preset
# labeling config or adapt the vector-store configuration accordingly.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# ---------------------------------------------------------------------------
# NCBI / Europe PMC full-text acquisition
# ---------------------------------------------------------------------------
# Optional but recommended for polite NCBI API usage.

NCBI_EMAIL=your_email@example.com
